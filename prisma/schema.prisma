generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                      String    @id @default(uuid())
  displayName             String?   @map("display_name")
  username                String    @unique
  email                   String    @unique
  passwordHash            String    @map("password_hash")
  role                    String    @default("PLAYER")
  platform                String?
  fcUsername              String?   @unique @map("fc_username")
  avatarUrl               String?   @map("avatar_url")
  bio                     String?
  country                 String    @default("Zimbabwe")
  city                    String?
  phone                   String?
  whatsapp                String?
  isShadowBanned          Boolean   @default(false) @map("is_shadow_banned")
  isVerified              Boolean   @default(false) @map("is_verified")
  isBanned                Boolean   @default(false) @map("is_banned")
  verificationToken       String?   @map("verification_token")
  verificationTokenExpiry DateTime? @map("verification_token_expiry")
  onboardingComplete      Boolean   @default(false) @map("onboarding_complete")
  lastLogin               DateTime? @map("last_login")
  lastActiveAt            DateTime? @map("last_active_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  clubId       String?   @unique @map("club_id")
  club         Club?     @relation("UserClubMembership", fields: [clubId], references: [id], onDelete: SetNull)
  joinedClubAt DateTime? @map("joined_club_at")

  managedClubId String? @unique @map("managed_club_id")
  managedClub   Club?   @relation("ClubManager")

  memberships     ClubMember[]
  clubRankings    ClubRanking[]
  playerRanking   PlayerRanking?
  playerStats     PlayerStats?
  mediaUploads    Media[]
  applications    ManagerApplication[] @relation("UserApplications")
  reviews         ManagerApplication[] @relation("ReviewedByUser")
  notifications   Notification[]
  activityLogs    ActivityLog[]
  posts           ClubPost[]
  likedPosts      PostLike[]
  postComments    PostComment[]
  clubActivities  ClubActivity[]
  followers       Follow[]             @relation("Followers")
  following       Follow[]             @relation("Following")
  disputeReports  Dispute[]            @relation("DisputeReporter")
  reports         Report[]             @relation("ReportReporter")
  auditLogs       AuditLog[]
  loginAttempts   LoginAttempt[]
  pointsLogs      PointsLog[]          @relation("PointsLogUser")
  givenPointsLogs PointsLog[]          @relation("PointsLogAdmin")

  createdClubs          Club[]         @relation("ClubCreator")
  matchPlayer1          MatchReport[]  @relation("MatchPlayer1")
  matchPlayer2          MatchReport[]  @relation("MatchPlayer2")
  matchWinner           MatchReport[]  @relation("MatchWinner")
  matchApprover         MatchReport[]  @relation("MatchApprover")
  matchSubmitter        MatchReport[]  @relation("MatchSubmitter")
  sentMatchRequests     MatchRequest[] @relation("SentMatchRequest")
  receivedMatchRequests MatchRequest[] @relation("ReceivedMatchRequest")

  sentWagers     Wager[] @relation("SentWagers")
  receivedWagers Wager[] @relation("ReceivedWagers")

  organizedTournaments     Tournament[]            @relation("TournamentOrganizer")
  tournamentParticipations TournamentParticipant[] @relation("TournamentParticipantUser")
  tournMatches1            TournamentMatch[]       @relation("TournMatchP1")
  tournMatches2            TournamentMatch[]       @relation("TournMatchP2")
  tournWins                TournamentMatch[]       @relation("TournMatchWinner")

  leagueAdmin              League[]                  @relation("LeagueAdmin")
  leagueParticipants       LeagueParticipant[]
  leagueStandings          LeagueStanding[]
  leagueHomeFixtures       LeagueFixture[]           @relation("HomeUser")
  leagueAwayFixtures       LeagueFixture[]           @relation("AwayUser")
  tournamentGroupStandings TournamentGroupStanding[]
  sentFriendRequests       Friend[]                  @relation("FriendRequestSent")
  receivedFriendRequests   Friend[]                  @relation("FriendRequestReceived")

  clubJoinRequests         ClubJoinRequest[]
  playerAchievements       PlayerAchievement[]
  chatMemberships          ChatMember[]
  chatMessages             ChatMessage[]
  matchScreenshots         MatchScreenshot[]       @relation("MatchScreenshotUploader")
  matchDisputes            MatchDispute[]            @relation("MatchDisputeReporter")
  matchDisputeResolved     MatchDispute[]            @relation("MatchDisputeResolver")
  notificationV2s          NotificationV2[]
  postReactions            PostReaction[]
  mvpVotes                 MatchMvpVote[]            @relation("MvpVoter")
  mvpAwards                MatchMvpVote[]            @relation("MvpPlayer")
  userActivities           UserActivity[]

  @@map("users")
}

model Club {
  id                String   @id @default(uuid())
  name              String   @unique
  slug              String   @unique
  tag               String?  @unique @map("tag")
  tagline           String?
  city              String
  country           String   @default("Zimbabwe")
  description       String?
  logoUrl           String?  @map("logo_url")
  bannerUrl         String?  @map("banner_url")
  isVerified        Boolean  @default(false) @map("is_verified")
  isBanned          Boolean  @default(false) @map("is_banned")
  status            String   @default("PENDING") @map("status")
  platform          String?
  membersInviteOnly Boolean  @default(false) @map("members_invite_only")
  clubXp            Int      @default(0) @map("club_xp")
  winRate           Float    @default(0) @map("win_rate")
  momentum          Int      @default(50)
  featuredLegends   String?  @map("featured_legends")
  trophies          String?  @map("trophies")
  joinCode          String?  @unique @map("join_code")
  isPublic          Boolean  @default(true) @map("is_public")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  managerId String @unique @map("manager_id")
  manager   User   @relation("ClubManager", fields: [managerId], references: [id])

  members         ClubMember[]
  rankings        ClubRanking[]
  globalRank      GlobalClubRanking?
  media           Media[]
  posts           ClubPost[]
  rivalries1      Rivalry[]          @relation("RivalClub1")
  rivalries2      Rivalry[]          @relation("RivalClub2")
  matches         MatchReport[]
  matchRequests   MatchRequest[]
  createdByUserId String?            @map("created_by_user_id")
  createdBy       User?              @relation("ClubCreator", fields: [createdByUserId], references: [id])
  clubMembers     User[]             @relation("UserClubMembership")
  achievements    ClubAchievement[]
  activity        ClubActivity[]
  joinRequests    ClubJoinRequest[]
  inviteCodes     ClubInviteCode[]
  chatRooms       ChatRoom[]

  @@map("clubs")
}

model ClubMember {
  id       String   @id @default(uuid())
  userId   String   @map("user_id")
  clubId   String   @map("club_id")
  role     String   @default("MEMBER")
  title    String?
  clubXp   Int      @default(0) @map("club_xp")
  status   String   @default("PENDING")
  joinedAt DateTime @default(now()) @map("joined_at")

  user User @relation(fields: [userId], references: [id])
  club Club @relation(fields: [clubId], references: [id])

  @@unique([userId, clubId])
  @@map("club_members")
}

model ClubAchievement {
  id          String   @id @default(uuid())
  clubId      String   @map("club_id")
  title       String
  description String?
  icon        String   @default("🏆")
  earnedAt    DateTime @map("earned_at")
  createdAt   DateTime @default(now()) @map("created_at")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@map("club_achievements")
}

model ClubActivity {
  id        String   @id @default(uuid())
  clubId    String   @map("club_id")
  userId    String   @map("user_id")
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([clubId, createdAt])
  @@map("club_activities")
}

model ClubRanking {
  id           String   @id @default(uuid())
  clubId       String   @map("club_id")
  userId       String   @map("user_id")
  rankPosition Int      @map("rank_position")
  prevPosition Int?     @map("prev_position")
  points       Int      @default(0)
  formHistory  String   @default("") @map("form_history")
  lastActive   DateTime @default(now()) @map("last_active")
  updatedAt    DateTime @updatedAt @map("updated_at")

  club Club @relation(fields: [clubId], references: [id])
  user User @relation(fields: [userId], references: [id])

  history RankingHistory[]

  @@unique([clubId, userId])
  @@map("club_rankings")
}

model RankingHistory {
  id          String   @id @default(uuid())
  rankingId   String   @map("ranking_id")
  oldPosition Int      @map("old_position")
  newPosition Int      @map("new_position")
  oldPoints   Int      @map("old_points")
  newPoints   Int      @map("new_points")
  changedAt   DateTime @default(now()) @map("changed_at")

  ranking ClubRanking @relation(fields: [rankingId], references: [id], onDelete: Cascade)

  @@map("ranking_history")
}

model GlobalClubRanking {
  id           String   @id @default(uuid())
  clubId       String   @unique @map("club_id")
  rankPosition Int      @map("rank_position")
  prevPosition Int?     @map("prev_position")
  totalPoints  Int      @default(0) @map("total_points")
  played       Int      @default(0)
  wins         Int      @default(0)
  losses       Int      @default(0)
  draws        Int      @default(0)
  goalsFor     Int      @default(0) @map("goals_for")
  goalsAgainst Int      @default(0) @map("goals_against")
  momentum     Int      @default(50)
  updatedAt    DateTime @updatedAt @map("updated_at")

  club Club @relation(fields: [clubId], references: [id])

  @@map("global_club_rankings")
}

model PointsLog {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  adminId      String?  @map("admin_id")
  pointsChange Int      @map("points_change")
  reason       String
  reasonText   String?
  matchId      String?  @map("match_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user          User         @relation("PointsLogUser", fields: [userId], references: [id])
  admin         User?        @relation("PointsLogAdmin", fields: [adminId], references: [id])
  playerStatsId String?      @map("player_stats_id")
  playerStats   PlayerStats? @relation("PointsLogPlayerStats", fields: [playerStatsId], references: [id])

  @@map("points_log")
}

model PlayerStats {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  matchesPlayed Int      @default(0) @map("matches_played")
  wins          Int      @default(0)
  losses        Int      @default(0)
  draws         Int      @default(0)
  goalsScored   Int      @default(0) @map("goals_scored")
  goalsConceded Int      @default(0) @map("goals_conceded")
  skillRating   Float    @default(1000) @map("skill_rating")
  points        Int      @default(0)
  formScore     Float    @default(0) @map("form_score")
  winStreak     Int      @default(0) @map("win_streak")
  mvpCount      Int      @default(0) @map("mvp_count")
  formHistory   String   @default("") @map("form_history")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id])
  pointsLogs PointsLog[] @relation("PointsLogPlayerStats")

  @@map("player_stats")
}

model PlayerRanking {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  rankPosition Int      @map("rank_position")
  prevPosition Int?     @map("prev_position")
  rankChange   Int      @default(0) @map("rank_change")
  points       Int      @default(0)
  finalScore   Float    @default(0) @map("final_score")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("player_rankings")
}

model Media {
  id           String   @id @default(uuid())
  clubId       String?  @map("club_id")
  uploadedById String   @map("uploaded_by")
  type         String
  url          String
  caption      String?
  createdAt    DateTime @default(now()) @map("created_at")

  club       Club? @relation(fields: [clubId], references: [id])
  uploadedBy User  @relation(fields: [uploadedById], references: [id])

  @@map("media")
}

model ManagerApplication {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  clubNameRequested String   @map("club_name_requested")
  description       String
  status            String   @default("PENDING")
  reviewedById      String?  @map("reviewed_by")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user       User  @relation("UserApplications", fields: [userId], references: [id])
  reviewedBy User? @relation("ReviewedByUser", fields: [reviewedById], references: [id])

  @@map("manager_applications")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  actionType String   @map("action_type")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

model ClubPost {
  id             String   @id @default(uuid())
  clubId         String   @map("club_id")
  authorId       String   @map("author_id")
  content        String
  imageUrl       String?  @map("image_url")
  isAnnouncement Boolean  @default(false) @map("is_announcement")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  club     Club          @relation(fields: [clubId], references: [id])
  author   User          @relation(fields: [authorId], references: [id])
  likes     PostLike[]
  comments  PostComment[]
  reactions PostReaction[]

  @@map("club_posts")
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post ClubPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@map("post_likes")
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  post ClubPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id])

  @@map("post_comments")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("Followers", fields: [followerId], references: [id])
  following User @relation("Following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
  @@map("follows")
}

model MatchReport {
  id            String    @id @default(uuid())
  clubId        String?   @map("club_id")
  player1Id     String    @map("player1_id")
  player2Id     String    @map("player2_id")
  winnerId      String?   @map("winner_id")
  score1        Int       @default(0) @map("score1")
  score2        Int       @default(0) @map("score2")
  status        String    @default("PENDING")
  statusRaw     String    @default("PENDING") @map("status_raw")
  confirmations Json?
  isDisputed    Boolean   @default(false) @map("is_disputed")
  notes         String?
  submittedById String    @map("submitted_by")
  approvedById  String?   @map("approved_by")
  approvedAt    DateTime? @map("approved_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  club        Club? @relation(fields: [clubId], references: [id])
  player1     User  @relation("MatchPlayer1", fields: [player1Id], references: [id])
  player2     User  @relation("MatchPlayer2", fields: [player2Id], references: [id])
  winner      User? @relation("MatchWinner", fields: [winnerId], references: [id])
  approvedBy  User? @relation("MatchApprover", fields: [approvedById], references: [id])
  submittedBy User  @relation("MatchSubmitter", fields: [submittedById], references: [id])
  screenshots MatchScreenshot[]
  mvpVotes    MatchMvpVote[]
  dispute     MatchDispute?

  @@index([player1Id, statusRaw])
  @@index([player2Id, statusRaw])
  @@map("match_reports")
}

model MatchRequest {
  id         String   @id @default(uuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  clubId     String?  @map("club_id")
  status     String   @default("PENDING")
  statusRaw  String   @default("PENDING") @map("status_raw")
  message    String?
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  sender   User  @relation("SentMatchRequest", fields: [senderId], references: [id])
  receiver User  @relation("ReceivedMatchRequest", fields: [receiverId], references: [id])
  club     Club? @relation(fields: [clubId], references: [id])

  @@index([receiverId, statusRaw])
  @@index([expiresAt])
  @@map("match_requests")
}

model Dispute {
  id           String    @id @default(uuid())
  matchId      String    @map("match_id")
  reportedById String    @map("reported_by")
  reason       String
  status       String    @default("OPEN")
  resolvedById String?   @map("resolved_by")
  resolution   String?
  createdAt    DateTime  @default(now()) @map("created_at")
  resolvedAt   DateTime? @map("resolved_at")

  reporter User @relation("DisputeReporter", fields: [reportedById], references: [id])

  @@map("disputes")
}

model Rivalry {
  id        String   @id @default(uuid())
  club1Id   String   @map("club1_id")
  club2Id   String   @map("club2_id")
  club1Wins Int      @default(0) @map("club1_wins")
  club2Wins Int      @default(0) @map("club2_wins")
  draws     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  club1 Club @relation("RivalClub1", fields: [club1Id], references: [id])
  club2 Club @relation("RivalClub2", fields: [club2Id], references: [id])

  @@unique([club1Id, club2Id])
  @@map("rivalries")
}

model Report {
  id           String   @id @default(uuid())
  reporterId   String   @map("reporter_id")
  targetId     String   @map("target_id")
  targetType   String   @map("target_type")
  reason       String
  status       String   @default("PENDING")
  reviewedById String?  @map("reviewed_by")
  action       String?
  createdAt    DateTime @default(now()) @map("created_at")

  reporter User @relation("ReportReporter", fields: [reporterId], references: [id])

  @@map("reports")
}

model AuditLog {
  id        String   @id @default(uuid())
  adminId   String   @map("admin_id")
  action    String
  target    String
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  admin User @relation(fields: [adminId], references: [id])

  @@map("audit_logs")
}

model Wager {
  id         String    @id @default(uuid())
  senderId   String    @map("sender_id")
  receiverId String    @map("receiver_id")
  amount     Int
  status     String    @default("PENDING")
  createdAt  DateTime  @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")
  winnerId   String?   @map("winner_id")

  sender   User @relation("SentWagers", fields: [senderId], references: [id])
  receiver User @relation("ReceivedWagers", fields: [receiverId], references: [id])

  @@map("wagers")
}

model ChallengeToken {
  id           String   @id @default(uuid())
  token        String   @unique
  challengerId String   @map("challenger_id")
  opponentId   String?  @map("opponent_id")
  matchType    String   @map("match_type")
  platform     String
  region       String
  wagerAmount  Int      @default(0) @map("wager_amount")
  expiresAt    DateTime @map("expires_at")
  used         Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("challenge_tokens")
}

model SystemHealth {
  id        String   @id @default(uuid())
  metric    String   @unique
  value     Float
  label     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_health")
}

model LoginAttempt {
  id        String   @id @default(uuid())
  ip        String   @default("unknown")
  userId    String?  @map("user_id")
  success   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([ip, success, createdAt])
  @@map("login_attempts")
}

// ═══════════════════════════════════════════════════════════
// LEAGUE SYSTEM
// ═══════════════════════════════════════════════════════════

model League {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  logo        String?
  type        String    @default("PUBLIC") // PUBLIC, PRIVATE, FRIENDS
  status      String    @default("DRAFT") // DRAFT, REGISTRATION, LIVE, COMPLETED
  maxPlayers  Int       @default(20)
  inviteCode  String?   @unique @map("invite_code")
  rounds      Int       @default(2) // number of rounds (1=单循环, 2=双循环)
  homeAway    Boolean   @default(true) // home/away fixtures
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  startedAt   DateTime? @map("started_at")
  endedAt     DateTime? @map("ended_at")

  adminId String @map("admin_id")
  admin   User   @relation("LeagueAdmin", fields: [adminId], references: [id])

  participants LeagueParticipant[]
  standings    LeagueStanding[]
  fixtures     LeagueFixture[]
  seasons      LeagueSeason[]
  inviteCodes  LeagueInviteCode[]

  @@map("leagues")
}

model LeagueParticipant {
  id       String   @id @default(uuid())
  leagueId String   @map("league_id")
  userId   String   @map("user_id")
  joinedAt DateTime @default(now()) @map("joined_at")

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@unique([leagueId, userId])
  @@map("league_participants")
}

model LeagueSeason {
  id           String    @id @default(uuid())
  leagueId     String    @map("league_id")
  seasonNumber Int       @default(1) @map("season_number")
  status       String    @default("ACTIVE") // ACTIVE, COMPLETED
  startedAt    DateTime  @default(now()) @map("started_at")
  endedAt      DateTime? @map("ended_at")

  league          League           @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  leagueStandings LeagueStanding[]
  leagueFixtures  LeagueFixture[]

  @@map("league_seasons")
}

model LeagueStanding {
  id             String   @id @default(uuid())
  leagueId       String   @map("league_id")
  userId         String   @map("user_id")
  seasonId       String   @map("season_id")
  points         Int      @default(0)
  played         Int      @default(0)
  wins           Int      @default(0)
  draws          Int      @default(0)
  losses         Int      @default(0)
  goalsFor       Int      @default(0) @map("goals_for")
  goalsAgainst   Int      @default(0) @map("goals_against")
  goalDifference Int      @default(0) @map("goal_difference")
  form           String   @default("") // "WWDLW" — last 5 results
  updatedAt      DateTime @updatedAt @map("updated_at")

  league League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id])
  season LeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId, seasonId])
  @@map("league_standings")
}

model LeagueFixture {
  id            String    @id @default(uuid())
  leagueId      String    @map("league_id")
  seasonId      String    @map("season_id")
  matchday      Int       @default(1)
  homeUserId    String    @map("home_user_id")
  awayUserId    String    @map("away_user_id")
  homeScore     Int?      @map("home_score")
  awayScore     Int?      @map("away_score")
  status        String    @default("PENDING") // PENDING, LIVE, COMPLETED
  matchReportId String?   @map("match_report_id")
  scheduledAt   DateTime? @map("scheduled_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  league   League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  season   LeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  homeUser User         @relation("HomeUser", fields: [homeUserId], references: [id])
  awayUser User         @relation("AwayUser", fields: [awayUserId], references: [id])

  @@index([leagueId, matchday])
  @@map("league_fixtures")
}

// ═══════════════════════════════════════════════════════════
// TOURNAMENT GROUP STAGES
// ═══════════════════════════════════════════════════════════

model TournamentGroup {
  id           String @id @default(uuid())
  tournamentId String @map("tournament_id")
  name         String @default("Group A")
  seed         Int    @default(0)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  standings TournamentGroupStanding[]

  @@unique([tournamentId, name])
  @@map("tournament_groups")
}

model TournamentGroupStanding {
  id             String @id @default(uuid())
  groupId        String @map("group_id")
  userId         String @map("user_id")
  points         Int    @default(0)
  played         Int    @default(0)
  wins           Int    @default(0)
  draws          Int    @default(0)
  losses         Int    @default(0)
  goalsFor       Int    @default(0) @map("goals_for")
  goalsAgainst   Int    @default(0) @map("goals_against")
  goalDifference Int    @default(0) @map("goal_difference")

  group TournamentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User            @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@map("tournament_group_standings")
}

// ═══════════════════════════════════════════════════════════
// FRIEND SYSTEM
// ═══════════════════════════════════════════════════════════

model Friend {
  id         String   @id @default(uuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  status     String   @default("PENDING") // PENDING, ACCEPTED, BLOCKED
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  sender   User @relation("FriendRequestSent", fields: [senderId], references: [id])
  receiver User @relation("FriendRequestReceived", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@map("friends")
}

model Tournament {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  type        String    @default("KNOCKOUT") // KNOCKOUT, ROUND_ROBIN, GROUPS
  status      String    @default("DRAFT") // DRAFT, REGISTRATION, LIVE, COMPLETED
  city        String?
  prizePool   Int       @default(0) @map("prize_pool")
  entryFee    Int       @default(0) @map("entry_fee") // USD cents per player
  creatorFee  Int       @default(0) @map("creator_fee") // USD cents paid by host
  platform    String? // CROSSPLAY, PS5, XBOX, PC
  maxPlayers  Int       @default(32) @map("max_players")
  minRank     Int?      @default(1) @map("min_rank") // minimum ZW rank to enter
  maxRank     Int?      @map("max_rank") // maximum ZW rank (null = no limit)
  bracket     String? // JSON string
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  startAt     DateTime? @map("start_at")
  endAt       DateTime? @map("end_at")

  organizerId String @map("organizer_id")
  organizer   User   @relation("TournamentOrganizer", fields: [organizerId], references: [id])

  participants TournamentParticipant[]
  matches      TournamentMatch[]
  groups       TournamentGroup[]
  inviteCodes  TournamentInviteCode[]

  @@map("tournaments")
}

model TournamentParticipant {
  id            String   @id @default(uuid())
  tournamentId  String   @map("tournament_id")
  userId        String   @map("user_id")
  seed          Int      @default(0)
  status        String   @default("REGISTERED") // REGISTERED, ELIMINATED, ACTIVE, WITHDRAWN
  finalPosition Int?     @map("final_position")
  createdAt     DateTime @default(now()) @map("created_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation("TournamentParticipantUser", fields: [userId], references: [id])

  @@unique([tournamentId, userId])
  @@map("tournament_participants")
}

model TournamentMatch {
  id            String    @id @default(uuid())
  tournamentId  String    @map("tournament_id")
  round         Int       @default(1)
  matchIndex    Int       @default(0) @map("match_index")
  player1Id     String?   @map("player1_id")
  player2Id     String?   @map("player2_id")
  winnerId      String?   @map("winner_id")
  score1        Int?      @map("score1")
  score2        Int?      @map("score2")
  status        String    @default("PENDING") // PENDING, READY, LIVE, COMPLETED
  matchReportId String?   @map("match_report_id")
  scheduledAt   DateTime? @map("scheduled_at")
  completedAt   DateTime? @map("completed_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player1    User?      @relation("TournMatchP1", fields: [player1Id], references: [id])
  player2    User?      @relation("TournMatchP2", fields: [player2Id], references: [id])
  winner     User?      @relation("TournMatchWinner", fields: [winnerId], references: [id])

  @@index([tournamentId, round])
  @@map("tournament_matches")
}

// ═══════════════════════════════════════════════════════════
// CLUB JOIN REQUESTS
// ═══════════════════════════════════════════════════════════

model ClubJoinRequest {
  id        String   @id @default(uuid())
  clubId    String   @map("club_id")
  userId    String   @map("user_id")
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  message   String?
  reviewedBy String? @map("reviewed_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([clubId, userId])
  @@map("club_join_requests")
}

// ═══════════════════════════════════════════════════════════
// CLUB INVITE CODES
// ═══════════════════════════════════════════════════════════

model ClubInviteCode {
  id        String   @id @default(uuid())
  clubId    String   @map("club_id")
  code      String   @unique
  uses      Int      @default(0)
  maxUses   Int?     @map("max_uses")
  expiresAt DateTime? @map("expires_at")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@map("club_invite_codes")
}

// ═══════════════════════════════════════════════════════════
// PLAYER ACHIEVEMENTS
// ═══════════════════════════════════════════════════════════

model PlayerAchievement {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  title       String
  description String?
  icon        String   @default("🏆")
  category    String   @default("GENERAL") // GENERAL, TOURNAMENT, LEAGUE, CLUB, SOCIAL, STREAK
  rarity      String   @default("COMMON") // COMMON, RARE, EPIC, LEGENDARY
  unlockedAt  DateTime @default(now()) @map("unlocked_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, title])
  @@map("player_achievements")
}

// ═══════════════════════════════════════════════════════════
// CHAT / MESSAGING SYSTEM
// ═══════════════════════════════════════════════════════════

model ChatRoom {
  id        String   @id @default(uuid())
  type      String   @default("DIRECT") // DIRECT, CLUB, TOURNAMENT, LEAGUE
  clubId    String?  @map("club_id")
  name      String?
  createdAt DateTime @default(now()) @map("created_at")

  club     Club?       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  messages ChatMessage[]
  members  ChatMember[]

  @@map("chat_rooms")
}

model ChatMember {
  id        String   @id @default(uuid())
  roomId    String   @map("room_id")
  userId    String   @map("user_id")
  role      String   @default("MEMBER") // MEMBER, MODERATOR, ADMIN
  joinedAt  DateTime @default(now()) @map("joined_at")

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@map("chat_members")
}

model ChatMessage {
  id        String   @id @default(uuid())
  roomId    String   @map("room_id")
  userId    String   @map("user_id")
  content   String
  type      String   @default("TEXT") // TEXT, SYSTEM, GIF, IMAGE
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id])

  @@index([roomId, createdAt])
  @@map("chat_messages")
}

// ═══════════════════════════════════════════════════════════
// MATCH SCREENSHOTS / VALIDATION
// ═══════════════════════════════════════════════════════════

model MatchScreenshot {
  id        String   @id @default(uuid())
  matchId   String   @map("match_id")
  url       String
  uploadedBy String  @map("uploaded_by")
  createdAt DateTime @default(now()) @map("created_at")

  match    MatchReport @relation(fields: [matchId], references: [id], onDelete: Cascade)
  uploader User        @relation("MatchScreenshotUploader", fields: [uploadedBy], references: [id])

  @@map("match_screenshots")
}

model MatchDispute {
  id             String    @id @default(uuid())
  matchId        String    @unique @map("match_id")
  reportedById   String    @map("reported_by")
  reason         String
  description    String?
  status         String    @default("OPEN") // OPEN, UNDER_REVIEW, RESOLVED, DISMISSED
  resolvedById   String?   @map("resolved_by")
  resolution     String?
  resolutionNote String?   @map("resolution_note")
  createdAt      DateTime  @default(now()) @map("created_at")
  resolvedAt     DateTime? @map("resolved_at")

  match     MatchReport @relation(fields: [matchId], references: [id], onDelete: Cascade)
  reporter  User        @relation("MatchDisputeReporter", fields: [reportedById], references: [id])
  resolver  User?       @relation("MatchDisputeResolver", fields: [resolvedById], references: [id])

  @@map("match_disputes")
}

// ═══════════════════════════════════════════════════════════
// NOTIFICATIONS V2 — RICH NOTIFICATIONS
// ═══════════════════════════════════════════════════════════

model NotificationV2 {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  type       String   // MATCH, TOURNAMENT, LEAGUE, CLUB, SOCIAL, ADMIN, SYSTEM
  title      String
  message    String
  link       String?
  imageUrl   String?  @map("image_url")
  metadata   Json?
  isRead     Boolean  @default(false) @map("is_read")
  isArchived Boolean  @default(false) @map("is_archived")
  createdAt  DateTime @default(now()) @map("created_at")
  readAt     DateTime? @map("read_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications_v2")
}

// ═══════════════════════════════════════════════════════════
// LEAGUE INVITE CODES
