// ═══════════════════════════════════════════════════════════
// TOURNAMENT INVITE CODES
// ═══════════════════════════════════════════════════════════

model TournamentInviteCode {
  id        String   @id @default(uuid())
  tournamentId String @map("tournament_id")
  code      String   @unique
  uses      Int      @default(0)
  maxUses   Int?     @map("max_uses")
  expiresAt DateTime? @map("expires_at")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@map("tournament_invite_codes")
}

// ═══════════════════════════════════════════════════════════
// SOCIAL — POST REACTIONS (emoji reactions on posts)
// ═══════════════════════════════════════════════════════════

model PostReaction {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  post ClubPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId, emoji])
  @@map("post_reactions")
}

// ═══════════════════════════════════════════════════════════
// MATCH MVP VOTES
// ═══════════════════════════════════════════════════════════

model MatchMvpVote {
  id        String   @id @default(uuid())
  matchId   String   @map("match_id")
  voterId   String   @map("voter_id")
  playerId  String   @map("player_id")
  createdAt DateTime @default(now()) @map("created_at")

  match  MatchReport @relation(fields: [matchId], references: [id], onDelete: Cascade)
  voter  User        @relation("MvpVoter", fields: [voterId], references: [id])
  player User        @relation("MvpPlayer", fields: [playerId], references: [id])

  @@unique([matchId, voterId])
  @@map("match_mvp_votes")
}

// ═══════════════════════════════════════════════════════════
// USER ACTIVITY FEED (global)
// ═══════════════════════════════════════════════════════════

model UserActivity {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   // MATCH_WON, MATCH_LOST, TOURNAMENT_JOINED, TOURNAMENT_WON, LEAGUE_JOINED, CLUB_JOINED, ACHIEVEMENT_UNLOCKED, RANK_CHANGED
  message   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("user_activities")
}
